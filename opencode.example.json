{
    "$schema": "https://opencode.ai/config.json",
    "model": "anthropic/claude-sonnet-4-20250514",
    "mcp": {
        "context7": {
            "type": "remote",
            "url": "https://mcp.context7.com/mcp",
            "headers": {
                "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
            },
            "enabled": true
        }
    },
    "agent": {
        "build": {
            "permission": {
                "bash": {
                    "*": "ask",
                    "git status": "allow",
                    "git diff*": "allow",
                    "git log*": "allow",
                    "npm run*": "allow",
                    "npx tsc*": "allow"
                }
            }
        }
    }
}